<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0D0D26"
    android:orientation="vertical"
    android:padding="14dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DailyTrack"
        android:textColor="#A78BFA"
        android:textSize="11sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/widget_next_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tidak ada kegiatan"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/widget_next_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap untuk buka app"
        android:textColor="#B8F0F0FF"
        android:textSize="11sp"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 kegiatan"
            android:textColor="#6BC8C8F0"
            android:textSize="11sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#6BC8C8F0"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/widget_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 selesai"
            android:textColor="#6BC8C8F0"
            android:textSize="11sp"/>

    </LinearLayout>

</LinearLayout>
