<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0D0D26"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/notif_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:background="#1A7C3AED"
            android:padding="6dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/notif_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B8F0F0FF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end"/>

        </LinearLayout>

        <TextView
            android:id="@+id/notif_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DailyTrack"
            android:textColor="#6BC8C8F0"
            android:textSize="10sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1EFFFFFF"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/notif_action_snooze"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nanti"
            android:textColor="#A78BFA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="#0FA78BFA"/>

        <TextView
            android:id="@+id/notif_action_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selesai"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="#7C3AED"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
